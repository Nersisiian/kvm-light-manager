# Environment
KVM_ENVIRONMENT=development
KVM_DEBUG=false

# API
KVM_API_HOST=0.0.0.0
KVM_API_PORT=8000
KVM_API_WORKERS=4

# Security (optional)
KVM_API_KEY_ENABLED=false
KVM_API_KEY_HEADER=X-API-Key
KVM_API_KEYS=

# Database
KVM_POSTGRES_HOST=postgres
KVM_POSTGRES_PORT=5432
KVM_POSTGRES_DB=kvm_light
KVM_POSTGRES_USER=kvm_user
KVM_POSTGRES_PASSWORD=secret
KVM_POSTGRES_POOL_SIZE=10
KVM_POSTGRES_MAX_OVERFLOW=20

# Redis
KVM_REDIS_HOST=redis
KVM_REDIS_PORT=6379
KVM_REDIS_DB=0
KVM_REDIS_PASSWORD=

# Agent ZeroMQ
KVM_AGENT_ZMQ_ENDPOINT=tcp://agent:5555
KVM_AGENT_REQUEST_TIMEOUT=30
KVM_AGENT_RETRY_ATTEMPTS=3
KVM_AGENT_HEARTBEAT_INTERVAL=10

# Circuit Breaker
KVM_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
KVM_CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# Logging
KVM_LOG_LEVEL=INFO
KVM_LOG_JSON=true
KVM_LOG_INCLUDE_HEADERS=false

# Metrics
KVM_METRICS_ENABLED=true